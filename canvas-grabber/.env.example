# Copy this file to .env and fill in your real values.
# NEVER commit your real .env — it contains your password.

# --- The only three settings you need to fill in ---

# Your Canvas username and password — the exact same ones you type on your
# school's Canvas login page. (NetID = whatever your school calls that
# username: NetID, student ID, login name, sometimes your email.)
CANVAS_NETID=your_netid_here
CANVAS_PASSWORD=your_password_here

# Your school's Canvas web address — copy it from your browser's address bar
# when you're logged into Canvas. Leave off any trailing "/" at the end.
# (e.g. https://canvas.myschool.edu)
CANVAS_BASE_URL=https://canvas.xxx.edu

# --- Everything below is OPTIONAL ---
# The tool runs fine with just the three settings above. Leave the rest
# commented out (the leading "#") unless a comment tells you you need it.

# Optional: the single sign-on / login host your Canvas redirects to.
# Defaults to login.<your-domain> (e.g. canvas.xxx.edu -> login.xxx.edu).
# Only set this if login fails because your SSO lives somewhere else.
# CANVAS_LOGIN_HOST=login.xxx.edu

# Optional: where raw JSON is saved (default: ./output)
# OUTPUT_DIR=./output

# --- Where the Markdown goes ---
# The output is always the same shape: one `canvas.md` hub per course (grade +
# outstanding items + the full "All assignments" table), plus vault-wide
# _upcoming.md and _grades.md.
# These vars only choose WHERE it's written.

# VAULT_DIR — your Obsidian vault folder (the friendly name for the destination).
# Each course's hub lands in a sub-folder of this; see vault-map.json below.
# VAULT_DIR=/path/to/Obsidian Vault/school

# SUMMARY_DIR — rarely needed. A fallback destination used only when VAULT_DIR
# is NOT set; defaults to OUTPUT_DIR (Markdown lands next to the raw JSON).
# Most people just use VAULT_DIR (or neither) and can ignore this.
# SUMMARY_DIR=./output

# VAULT_MAP — maps a Canvas course code to its sub-folder, so the hub sits next
# to that class's notes (see vault-map.example.json). Unmapped courses use their
# course code (e.g. PSYX362/) as the folder name.
# VAULT_MAP=./vault-map.json

# Optional: timezone for due dates (default: America/Denver)
# CANVAS_TZ=America/Denver

# Optional: which browser engine Playwright uses for login (default: webkit).
# If login fails or webkit won't install on your system, try chromium.
# Whatever you set here, install it with: npx playwright install <engine>
# PLAYWRIGHT_BROWSER=webkit

